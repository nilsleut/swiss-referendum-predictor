# Copy to .env and fill in values before running locally.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/referendum_db

# Absolute path to the models/onnx directory produced by ml/src/export.py
ONNX_MODEL_DIR=/absolute/path/to/ml/models/onnx

MODEL_VERSION=v1.0.0

PORT=3000

# Set to "true" to enable detailed Fastify request logs
LOG_PRETTY=true
